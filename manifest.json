{
  "name": "cortex-plugin-email",
  "version": "2.0.0",
  "description": "Generic email integration — send via SMTP, read via IMAP. Works with Gmail, Outlook, Yahoo, and any email provider.",
  "kind": "esm",
  "entryPoint": "mod.ts",
  "runtime": "deno",
  "author": "CortexPrism Contributors",
  "license": "MIT",
  "repository": "https://github.com/CortexPrism/cortex-plugin-email",
  "homepage": "https://github.com/CortexPrism/cortex-plugin-email",
  "capabilities": [
    "tools",
    "network:fetch"
  ],
  "tools": [
    {
      "name": "email_list",
      "description": "List emails from the configured IMAP mailbox",
      "params": [
        {
          "name": "max_results",
          "type": "number",
          "description": "Maximum number of emails to return",
          "required": false,
          "default": 20
        },
        {
          "name": "query",
          "type": "string",
          "description": "Search query (searches subject and from fields)",
          "required": false
        },
        {
          "name": "mailbox",
          "type": "string",
          "description": "IMAP mailbox/folder name (default: INBOX)",
          "required": false
        }
      ]
    },
    {
      "name": "email_get",
      "description": "Get a specific email by UID from the IMAP mailbox",
      "params": [
        {
          "name": "email_id",
          "type": "string",
          "description": "Email UID to retrieve",
          "required": true
        },
        {
          "name": "format",
          "type": "string",
          "description": "Response format: full, metadata, minimal",
          "required": false,
          "enum": ["full", "metadata", "minimal"],
          "default": "full"
        },
        {
          "name": "mailbox",
          "type": "string",
          "description": "IMAP mailbox/folder name (default: INBOX)",
          "required": false
        }
      ]
    },
    {
      "name": "email_send",
      "description": "Send an email via SMTP",
      "params": [
        {
          "name": "to",
          "type": "string",
          "description": "Recipient email address(es), comma-separated",
          "required": true
        },
        {
          "name": "subject",
          "type": "string",
          "description": "Email subject",
          "required": true
        },
        {
          "name": "body",
          "type": "string",
          "description": "Email body content (plain text or HTML)",
          "required": true
        },
        {
          "name": "cc",
          "type": "string",
          "description": "CC recipients, comma-separated",
          "required": false
        },
        {
          "name": "bcc",
          "type": "string",
          "description": "BCC recipients, comma-separated",
          "required": false
        },
        {
          "name": "is_html",
          "type": "boolean",
          "description": "Whether body is HTML",
          "required": false,
          "default": false
        }
      ]
    },
    {
      "name": "email_draft",
      "description": "Create a draft email (returns RFC 2822 message for review; does not send)",
      "params": [
        {
          "name": "to",
          "type": "string",
          "description": "Recipient email address(es)",
          "required": true
        },
        {
          "name": "subject",
          "type": "string",
          "description": "Email subject",
          "required": true
        },
        {
          "name": "body",
          "type": "string",
          "description": "Email body content",
          "required": true
        },
        {
          "name": "cc",
          "type": "string",
          "description": "CC recipients, comma-separated",
          "required": false
        },
        {
          "name": "is_html",
          "type": "boolean",
          "description": "Whether body is HTML",
          "required": false,
          "default": false
        }
      ]
    },
    {
      "name": "email_summarize_thread",
      "description": "Summarize an email thread by searching for related messages",
      "params": [
        {
          "name": "thread_id",
          "type": "string",
          "description": "Thread identifier (Message-ID or subject search term)",
          "required": true
        },
        {
          "name": "mailbox",
          "type": "string",
          "description": "IMAP mailbox/folder name (default: INBOX)",
          "required": false
        }
      ]
    },
    {
      "name": "email_extract_actions",
      "description": "Extract action items from email bodies",
      "params": [
        {
          "name": "email_ids",
          "type": "string",
          "description": "Comma-separated email UIDs to analyze",
          "required": true
        },
        {
          "name": "mailbox",
          "type": "string",
          "description": "IMAP mailbox/folder name (default: INBOX)",
          "required": false
        }
      ]
    }
  ],
  "ui": {
    "settings": [
      {
        "section": "SMTP (Sending)",
        "fields": [
          {
            "key": "smtpHost",
            "label": "SMTP Host",
            "type": "text",
            "description": "SMTP server hostname (e.g., smtp.gmail.com)",
            "required": true
          },
          {
            "key": "smtpPort",
            "label": "SMTP Port",
            "type": "number",
            "description": "SMTP server port (587 for STARTTLS, 465 for TLS)",
            "required": false,
            "default": 587
          },
          {
            "key": "smtpUser",
            "label": "SMTP Username",
            "type": "text",
            "description": "SMTP authentication username (usually full email address)",
            "required": true
          },
          {
            "key": "smtpPassword",
            "label": "SMTP Password",
            "type": "secret",
            "description": "SMTP password or app-specific password",
            "required": true
          }
        ]
      },
      {
        "section": "IMAP (Reading)",
        "fields": [
          {
            "key": "imapHost",
            "label": "IMAP Host",
            "type": "text",
            "description": "IMAP server hostname (e.g., imap.gmail.com)",
            "required": true
          },
          {
            "key": "imapPort",
            "label": "IMAP Port",
            "type": "number",
            "description": "IMAP server port (993 for TLS, 143 for STARTTLS)",
            "required": false,
            "default": 993
          },
          {
            "key": "imapUser",
            "label": "IMAP Username",
            "type": "text",
            "description": "IMAP authentication username (usually full email address)",
            "required": true
          },
          {
            "key": "imapPassword",
            "label": "IMAP Password",
            "type": "secret",
            "description": "IMAP password or app-specific password",
            "required": true
          }
        ]
      },
      {
        "section": "General",
        "fields": [
          {
            "key": "fromEmail",
            "label": "From Email Address",
            "type": "text",
            "description": "Email address used in the From header (defaults to SMTP/IMAP username)",
            "required": false
          }
        ]
      }
    ]
  },
  "dependencies": {},
  "peerDependencies": {
    "cortex": ">=1.0.0"
  },
  "aiDisclosure": {
    "tools": ["copilot"],
    "generatedFiles": ["mod.ts", "smtp.ts", "imap.ts", "types.ts", "README.md"],
    "humanReviewed": true,
    "statement": "All AI-generated code was reviewed, tested, and verified for correctness and security."
  }
}
